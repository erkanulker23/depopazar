#!/usr/bin/env php
<?php
/**
 * DepoPazar – Artisan (Forge / Laravel deploy uyumlu)
 * migrate: schema + SQL migration (schema_migrations ile yalnizca bir kez)
 * Seed deploy'da calismaz; ilk kurulum: ARTISAN_RUN_SEED=1 php artisan migrate --force
 * optimize, config:cache, route:cache, view:cache vb.: no-op (saf PHP uygulaması)
 */
$command = isset($argv[1]) ? trim($argv[1]) : '';

if ($command === '--help' || $command === '-h') {
    echo "Kullanım: php artisan migrate [--force]\n";
    echo "  Forge deploy: optimize, config:cache, route:cache, view:cache (no-op)\n";
    exit(0);
}

// Laravel Forge standart deploy komutları – bu projede Laravel yok, güvenli no-op
$noopCommands = [
    'optimize',
    'config:cache',
    'route:cache',
    'view:cache',
    'event:cache',
    'config:clear',
    'route:clear',
    'view:clear',
    'cache:clear',
    'clear-compiled',
    'storage:link',
    'queue:restart',
    'down',
    'up',
    'about',
    'env',
    'inspire',
];
if (in_array($command, $noopCommands, true)) {
    exit(0);
}

if ($command === 'overdue:remind') {
    $root = __DIR__;
    if (basename($root) === 'php-app') {
        $root = dirname($root);
    }
    $script = $root . '/php-app/scripts/overdue-remind.php';
    if (!is_file($script)) {
        fwrite(STDERR, "Hata: overdue-remind.php bulunamadı\n");
        exit(1);
    }
    passthru('php ' . escapeshellarg($script), $ret);
    exit($ret);
}

// migrate, migrate --force, veya boş komut (sadece "php artisan")
if ($command !== 'migrate' && $command !== '' && $command !== '--force') {
    fwrite(STDERR, "Bilinmeyen komut: " . (string)$command . "\n");
    fwrite(STDERR, "Kullanım: php artisan migrate [--force] | php artisan overdue:remind\n");
    exit(1);
}

// Proje kökü: artisan dosyası kökte veya php-app içinde olabilir
$root = __DIR__;
if (basename($root) === 'php-app') {
    $root = dirname($root);
}
$phpApp = $root . '/php-app';

$envFile = file_exists($root . '/.env') ? $root . '/.env' : (file_exists($phpApp . '/.env') ? $phpApp . '/.env' : null);
if ($envFile) {
    $lines = file($envFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        $line = trim($line);
        if ($line === '' || $line[0] === '#') continue;
        if (preg_match('/^([A-Za-z_][A-Za-z0-9_]*)=(.*)$/', $line, $m)) {
            putenv(trim($m[1]) . '=' . trim($m[2], " \t\"'"));
        }
    }
}

$host     = getenv('DB_HOST') ?: '127.0.0.1';
$port     = getenv('DB_PORT') ?: '3306';
$database = getenv('DB_DATABASE') ?: 'depotakip';
$username = getenv('DB_USERNAME') ?: 'root';
$password = getenv('DB_PASSWORD') ?: '';

// Deploy sırasında oluşturulan db.local.php varsa onu kullan (sunucuda .env dosyası olmayabilir)
if (file_exists($phpApp . '/config/db.local.php')) {
    $code = file_get_contents($phpApp . '/config/db.local.php');
    if (preg_match("/\\\$host\s*=\s*'([^']*)'/", $code, $m)) $host = $m[1];
    if (preg_match("/\\\$port\s*=\s*'([^']*)'/", $code, $m)) $port = $m[1];
    if (preg_match("/\\\$db\s*=\s*'([^']*)'/", $code, $m)) $database = $m[1];
    if (preg_match("/\\\$user\s*=\s*'([^']*)'/", $code, $m)) $username = $m[1];
    if (preg_match("/\\\$pass\s*=\s*'([^']*)'/", $code, $m)) $password = $m[1];
}

$schemaPath    = $phpApp . '/sql/schema.sql';
$migrationsDir = $phpApp . '/sql/migrations';

if (!is_file($schemaPath)) {
    fwrite(STDERR, "Hata: schema.sql bulunamadı: $schemaPath\n");
    exit(1);
}
if (!is_dir($migrationsDir)) {
    fwrite(STDERR, "Hata: migrations dizini yok: $migrationsDir\n");
    exit(1);
}

function run_mysql_file($mysqlCmd, $host, $port, $username, $password, $database, $file) {
    $args = [
        '-h', $host,
        '-P', $port,
        '-u', $username,
    ];
    if ($password !== '') {
        $args[] = '-p' . $password;
    }
    $args[] = $database;
    $cmd = escapeshellcmd($mysqlCmd);
    foreach ($args as $a) {
        $cmd .= ' ' . escapeshellarg($a);
    }
    $cmd .= ' < ' . escapeshellarg($file);
    $out = [];
    $ret = -1;
    exec($cmd . ' 2>&1', $out, $ret);
    return [$ret === 0, implode("\n", $out)];
}

function run_mysql_file_pdo(PDO $pdo, $file) {
    $sql = file_get_contents($file);
    if (trim($sql) === '') return [true, ''];
    try {
        $pdo->exec($sql);
        return [true, ''];
    } catch (Throwable $e) {
        return [false, $e->getMessage()];
    }
}

function ensure_migration_table(PDO $pdo): void
{
    $pdo->exec(
        'CREATE TABLE IF NOT EXISTS `schema_migrations` (
            `id` INT UNSIGNED NOT NULL AUTO_INCREMENT,
            `migration` VARCHAR(255) NOT NULL,
            `applied_at` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
            PRIMARY KEY (`id`),
            UNIQUE KEY `uq_schema_migrations_migration` (`migration`)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci'
    );
}

function get_applied_migrations(PDO $pdo): array
{
    ensure_migration_table($pdo);
    $rows = $pdo->query('SELECT migration FROM schema_migrations')->fetchAll(PDO::FETCH_COLUMN);
    return array_flip($rows ?: []);
}

function mark_migration_applied(PDO $pdo, string $name): void
{
    $stmt = $pdo->prepare('INSERT IGNORE INTO schema_migrations (migration) VALUES (?)');
    $stmt->execute([$name]);
}

function database_has_existing_data(PDO $pdo): bool
{
    try {
        $pdo->query('SELECT 1 FROM companies LIMIT 1');
        return (int) $pdo->query('SELECT COUNT(*) FROM companies')->fetchColumn() > 0;
    } catch (Throwable $e) {
        try {
            $pdo->query('SELECT 1 FROM users LIMIT 1');
            return (int) $pdo->query('SELECT COUNT(*) FROM users WHERE deleted_at IS NULL')->fetchColumn() > 0;
        } catch (Throwable $e2) {
            return false;
        }
    }
}

/** Migration daha once uygulanmis mi (Duplicate column vb.) */
function is_migration_already_applied_error(string $err): bool
{
    $err = strtolower($err);
    $needles = [
        'duplicate column',
        'duplicate key name',
        'duplicate entry',
        'already exists',
        'check that column/key exists',
        'multiple primary key',
    ];
    foreach ($needles as $needle) {
        if (str_contains($err, $needle)) {
            return true;
        }
    }
    return false;
}

function run_schema_if_needed(PDO $pdo, bool $useMysqlCli, string $mysqlCmd, string $host, string $port, string $username, string $password, string $database, string $schemaPath): void
{
    echo "Schema kontrol ediliyor... ";
    if ($useMysqlCli) {
        list($ok, $err) = run_mysql_file($mysqlCmd, $host, $port, $username, $password, $database, $schemaPath);
    } else {
        list($ok, $err) = run_mysql_file_pdo($pdo, $schemaPath);
    }
    if ($ok) {
        echo "OK\n";
    } else {
        echo "atlandi (tablolar zaten mevcut)\n";
        if ($err !== '') {
            echo trim($err) . "\n";
        }
    }
}

$useMysqlCli = false;
$mysqlCmd = 'mysql';
$which = trim((string) shell_exec('which mysql 2>/dev/null'));
if ($which !== '') {
    $mysqlCmd = $which;
    $useMysqlCli = true;
}

$pdo = null;
if (!$useMysqlCli) {
    try {
        $dsn = "mysql:host=$host;port=$port;dbname=$database;charset=utf8mb4";
        $pdo = new PDO($dsn, $username, $password, [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
        echo "MySQL CLI bulunamadı; PDO ile çalıştırılıyor (DELIMITER içeren migration'lar atlanabilir).\n";
    } catch (Throwable $e) {
        fwrite(STDERR, "Veritabanı bağlantı hatası: " . $e->getMessage() . "\n");
        fwrite(STDERR, "Sunucuda 'mysql' komutunun yüklü olduğundan emin olun: apt install mysql-client\n");
        exit(1);
    }
}

echo "Veritabanı: $database @ $host:$port\n";

// PDO her zaman migration takibi icin (mysql CLI migration calistirsa bile)
if ($pdo === null) {
    try {
        $dsn = "mysql:host=$host;port=$port;dbname=$database;charset=utf8mb4";
        $pdo = new PDO($dsn, $username, $password, [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
    } catch (Throwable $e) {
        fwrite(STDERR, "Veritabani baglanti hatasi (migration takibi): " . $e->getMessage() . "\n");
        exit(1);
    }
}

ensure_migration_table($pdo);
$files = glob($migrationsDir . '/*.sql');
sort($files);
$applied = get_applied_migrations($pdo);
$pending = [];
foreach ($files as $f) {
    $name = basename($f);
    if (trim((string) file_get_contents($f)) === '') {
        continue;
    }
    if (!isset($applied[$name])) {
        $pending[] = $f;
    }
}

// Mevcut canli veritabani: daha once elle/eskiden migrate edilmis, kayit tablosu bos
if (empty($applied)) {
    run_schema_if_needed($pdo, $useMysqlCli, $mysqlCmd, $host, $port, $username, $password, $database, $schemaPath);
    $pending = [];
    foreach ($files as $f) {
        $name = basename($f);
        if (trim((string) file_get_contents($f)) === '') {
            continue;
        }
        $pending[] = $f;
    }
    if (database_has_existing_data($pdo)) {
        echo "Mevcut veritabani — bekleyen migration'lar kontrol edilecek (zaten uygulananlar atlanir).\n";
    }
} else {
    echo "Uygulanmis migration: " . count($applied) . ", bekleyen: " . count($pending) . "\n";
}

$done = 0;
$skipped = 0;
$failed = [];
foreach ($pending as $f) {
    $name = basename($f);
    if ($useMysqlCli) {
        list($ok, $err) = run_mysql_file($mysqlCmd, $host, $port, $username, $password, $database, $f);
    } else {
        list($ok, $err) = run_mysql_file_pdo($pdo, $f);
    }
    if ($ok) {
        mark_migration_applied($pdo, $name);
        echo "  Migration: $name\n";
        $done++;
    } elseif (is_migration_already_applied_error($err)) {
        mark_migration_applied($pdo, $name);
        echo "  Migration (zaten uygulanmis): $name\n";
        $skipped++;
    } else {
        $failed[] = [$name, $err];
    }
}

if (!empty($failed)) {
    foreach ($failed as list($name, $err)) {
        fwrite(STDERR, "  Hata: $name - " . trim($err) . "\n");
    }
    fwrite(STDERR, "Bazi migration'lar basarisiz. DELIMITER iceren dosyalar icin sunucuda mysql istemcisi gerekir.\n");
    exit(1);
}

echo "Toplam $done yeni migration uygulandi" . ($skipped > 0 ? ", $skipped zaten uygulanmis" : '') . ".\n";

// Seed YALNIZCA ilk kurulum icin: ARTISAN_RUN_SEED=1 ile calistirin (deploy'da varsayilan kapali)
$runSeed = getenv('ARTISAN_RUN_SEED') === '1' && getenv('ARTISAN_SKIP_SEED') !== '1';
if ($runSeed) {
    $seedScript = $phpApp . '/seed.php';
    if (is_file($seedScript)) {
        echo "Seed calistiriliyor (ARTISAN_RUN_SEED=1)...\n";
        passthru('php ' . escapeshellarg($seedScript) . ' --skip-migrate', $seedRet);
        if ($seedRet !== 0) {
            fwrite(STDERR, "Uyari: seed.php cikis kodu: $seedRet\n");
        }
    }
}

@mkdir($phpApp . '/public/uploads/company', 0755, true);

exit(0);
